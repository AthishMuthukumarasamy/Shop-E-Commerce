@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-primary">
            Welcome to ShopSphere 🌐
        </h1>

        <p class="lead text-muted">
            Your world of shopping starts here.
        </p>

        <a asp-controller="Products"
           asp-action="Index"
           class="btn btn-primary btn-lg mt-3">
            🛒 Explore Products
        </a>
    </div>

    <!-- Features Section -->
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow h-100 border-0">
                <div class="card-body text-center">
                    <h1>🚚</h1>
                    <h4 class="mt-3">Fast Delivery</h4>
                    <p class="text-muted">
                        Get your products delivered quickly and safely to your doorstep.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow h-100 border-0">
                <div class="card-body text-center">
                    <h1>💳</h1>
                    <h4 class="mt-3">Secure Payment</h4>
                    <p class="text-muted">
                        Multiple secure payment methods for a worry-free shopping experience.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow h-100 border-0">
                <div class="card-body text-center">
                    <h1>⭐</h1>
                    <h4 class="mt-3">Quality Products</h4>
                    <p class="text-muted">
                        We provide only the best products carefully selected for our customers.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- Additional Banner -->
    <div class="bg-light rounded shadow p-5 text-center mt-5">
        <h2 class="text-dark">
            Discover Amazing Deals Every Day!
        </h2>

        <p class="text-muted">
            Shop from a wide range of products with exciting offers and discounts.
        </p>

        <a asp-controller="Products"
           asp-action="Index"
           class="btn btn-success btn-lg">
            Start Shopping
        </a>
    </div>

</div>