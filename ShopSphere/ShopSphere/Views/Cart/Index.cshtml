@model ShopSphere.DatabaseModels.Cart

<h1>Shopping Cart 🛒</h1>

@if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
{
    <p>Your cart is empty.</p>
}
else
{
    decimal grandTotal = 0;

    <table class="table table-bordered table-striped">

        <thead class="table-dark">
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model.CartItems)
            {
                decimal total = item.UnitPrice * item.Quantity;
                grandTotal += total;

                <tr>
                    <td>
                        @item.Product?.ProductName
                    </td>

                    <td>
                        ₹@item.UnitPrice
                    </td>

                    <td>
                        <a asp-action="Decrease"
                           asp-route-id="@item.CartItemId"
                           class="btn btn-warning btn-sm">-</a>

                        <span class="mx-2">@item.Quantity</span>

                        <a asp-action="Increase"
                           asp-route-id="@item.CartItemId"
                           class="btn btn-success btn-sm">+</a>
                    </td>

                    <td>
                        ₹@total
                    </td>

                    <td>
                        <a asp-action="Remove"
                           asp-route-id="@item.CartItemId"
                           class="btn btn-danger btn-sm">
                            Remove
                        </a>
                    </td>
                </tr>
            }

        </tbody>
    </table>

    <div class="text-end">
        <h3 class="text-success">
            Grand Total: ₹@grandTotal
        </h3>
    </div>

    <div class="mt-3 text-end">

        <a asp-controller="Products"
           asp-action="Index"
           class="btn btn-primary">
            Continue Shopping
        </a>

        <a asp-controller="Order"
           asp-action="PlaceOrder"
           class="btn btn-success">
            Checkout
        </a>

    </div>
}