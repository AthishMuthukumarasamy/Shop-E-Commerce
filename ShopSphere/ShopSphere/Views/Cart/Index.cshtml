@model List<ShopSphere.Models.CartItem>

<h1>Shopping Cart</h1>

@if (Model.Count == 0)
{
    <p>Your cart is empty.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>₹@item.Price</td>
                    <td>@item.Quantity</td>
                    <td>₹@(item.Price* item.Quantity)</td>
                </tr>
            }

        </tbody>
    </table>
}