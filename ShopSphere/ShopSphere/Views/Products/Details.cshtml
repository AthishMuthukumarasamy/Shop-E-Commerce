@model ShopSphere.DatabaseModels.Product

<div class="row">

    <div class="col-md-6">

        <img src="@Model.ProductImages.FirstOrDefault()?.ImageUrl"
             class="img-fluid rounded shadow"
             style="max-height:400px; object-fit:cover;" />

    </div>

    <div class="col-md-6">

        <h2>@Model.ProductName</h2>

        <h4 class="text-success">₹@Model.Price</h4>

        <p class="mt-3">
            @Model.Description
        </p>

        <p>
            <b>Category:</b> @Model.Category?.CategoryName
        </p>

        <p>
            <b>Brand:</b> @Model.Brand?.BrandName
        </p>

        <a asp-controller="Cart"
           asp-action="AddToCart"
           asp-route-productId="@Model.ProductId"
           class="btn btn-success">
            Add to Cart 🛒
        </a>

        <a asp-action="Index"
           class="btn btn-secondary">
            Back
        </a>

    </div>

</div>