@model ShopSphere.DatabaseModels.Product

@{
    ViewData["Title"] = "Product Details";
    var image = Model.ProductImages.FirstOrDefault(i => i.IsPrimary == true);
}

<h2>@Model.ProductName</h2>

<div class="row">

    <div class="col-md-5">

        @if (image != null)
        {
            <img src="@image.ImageUrl"
                 class="img-fluid rounded shadow" />
        }

    </div>

    <div class="col-md-7">

        <h4 class="text-success">
            ₹@Model.Price
        </h4>

        <p>
            @Model.Description
        </p>

        <p>
            <strong>Category:</strong>
            @Model.Category.CategoryName
        </p>

        <p>
            <strong>Brand:</strong>
            @Model.Brand.BrandName
        </p>

        <p>
            <strong>Stock:</strong>
            @Model.Stock
        </p>

    </div>

</div>